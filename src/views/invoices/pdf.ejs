        </ol>

        <div class="disclaimer">

            Disclaimer:
            I hereby acknowledge that I accept the service

            <span style="
                    color:#8cc63f;
                    font-weight:bold;
                    ">
                terms & conditions*
            </span>

        </div>

        <div class="page-number">
            Page: 2 of 2
        </div>

        <div class="contact-footer">

            Contact Support

            &nbsp;&nbsp;&nbsp;

            9999759911

            &nbsp;&nbsp;&nbsp;

            support@uclean.in

        </div>
</body>

</html>