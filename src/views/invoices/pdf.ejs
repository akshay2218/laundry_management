<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <title>
        <%= invoice.invoiceNumber %>
    </title>

    <style>
        body {
            font-family: Arial, Helvetica, sans-serif;
            font-size: 12px;
            color: #333;
            padding: 20px;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid #198754;
            padding-bottom: 15px;
            margin-bottom: 20px;
        }

        .logo {
            font-size: 30px;
            font-weight: bold;
            color: #198754;
        }

        .company {
            text-align: right;
        }

        .company h2 {
            margin: 0;
            color: #198754;
        }

        .section {
            margin-bottom: 20px;
        }

        .row {
            width: 100%;
            margin-bottom: 15px;
        }

        .col {
            display: inline-block;
            vertical-align: top;
            width: 48%;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        table th {
            background: #198754;
            color: #fff;
            padding: 10px;
            border: 1px solid #ddd;
        }

        table td {
            border: 1px solid #ddd;
            padding: 8px;
        }

        .text-right {
            text-align: right;
        }

        .summary {
            width: 350px;
            margin-left: auto;
            margin-top: 20px;
        }

        .summary td {
            padding: 8px;
        }

        .grand-total {
            background: #198754;
            color: white;
            font-weight: bold;
        }

        .footer {
            margin-top: 40px;
            border-top: 1px solid #ddd;
            padding-top: 20px;
        }

        .small {
            font-size: 10px;
            color: #666;
        }

        .section-title {
            background: #ececec;
            padding: 12px 15px;
            border-radius: 8px;
            font-size: 18px;
            font-weight: bold;
            margin-bottom: 15px;
        }

        .contact-footer {
            background: #00573f;
            color: white;
            padding: 15px;
            text-align: center;
            font-weight: bold;
        }

        .disclaimer {
            border-top: 1px solid #ddd;
            padding-top: 10px;
            margin-top: 20px;
            font-size: 12px;
        }
    </style>

</head>

<body>

    <!-- HEADER -->

    <div style="
    background:#00573f;
    padding:20px;
    margin:-20px -20px 30px -20px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    ">

        <!-- <img src="/images/uc-white.png" alt="Logo" style="height:60px;"> -->
        <div>

            <div class="logo">
                UClean
            </div>

            <div>
                We ❤️ Laundry
            </div>

        </div>

        <div style="
        color:white;
        font-size:20px;
        font-weight:bold;
        ">
            www.ucleanlaundry.com
        </div>

    </div>

    <!-- CUSTOMER -->

    <div class="section">

        <div class="row">

            <div class="col">

                <div class="section-title">
                    CUSTOMER DETAILS
                </div>

                <p>
                    <strong>Name:</strong>
                    <%= invoice.orderId?.customerId?.name || '-' %>
                </p>

                <p>
                    <strong>Phone:</strong>
                    <%= invoice.orderId?.customerId?.phone || '-' %>
                </p>

                <p>
                    <strong>GST No:</strong>
                    <%= invoice.customerGST || '-' %>
                </p>

            </div>

            <div class="col">

                <div class="section-title">
                    STORE DETAILS
                </div>
                <p>
                    <strong>Code:</strong>
                    UC772
                </p>

                <p>
                    <strong>Name:</strong>
                    UClean Dombivli Thane
                </p>

                <p>
                    <strong>GSTIN:</strong>
                    27ABNFR4579F1ZM
                </p>

                <p>
                    <strong>Phone:</strong>
                    +91 9372550037
                </p>

                <p>
                    <strong>Address:</strong>
                    Shop No 17,
                    Regency Anantam,
                    Dombivli East
                </p>

            </div>

            <div class="col">

                <div class="section-title">
                    ORDER DETAILS
                </div>
                <p>
                    <strong>Order No:</strong>
                    <%= invoice.orderId?.orderNumber || '-' %>
                </p>

                <p>
                    <strong>Challan No:</strong>
                    <%= invoice.challanNumber || '-' %>
                </p>

                <p>
                    <strong>Delivery Date:</strong>
                    <%= invoice.deliveryDate ? new Date(invoice.deliveryDate).toLocaleDateString('en-IN') : '-' %>
                </p>

                <p>
                    <strong>Delivery Time:</strong>
                    <%= invoice.deliveryTime || '-' %>
                </p>

            </div>

        </div>

    </div>


    <!-- ITEMS -->

    <div class="section">

        <table>

            <thead>

                <tr>
                    <th>S.NO.</th>
                    <th>SERVICE</th>
                    <th>ITEMS</th>
                    <th>RATE</th>
                    <th>QTY</th>
                    <th>AMOUNT</th>
                </tr>

            </thead>

            <tbody>

                <% let subTotal=0; %>

                    <% invoice.items.forEach((item,index)=>{ %>

                        <% const amount=item.quantity * item.rate; %>

                            <% subTotal +=amount; %>

                                <tr>
                                    <td>
                                        <%= index + 1 %>
                                    </td>
                                    <td>
                                        <%= item.serviceName %>
                                    </td>
                                    <td>
                                        <%= item.itemName %>
                                    </td>
                                    <td>₹<%= item.rate %>
                                    </td>
                                    <td>
                                        <%= item.quantity %>
                                    </td>
                                    <td>₹<%= item.amount %>
                                    </td>
                                </tr>

                                <% }) %>

            </tbody>

        </table>

    </div>

    <!-- TOTALS -->

    <% const gstAmount=invoice.applyGST ? invoice.gstAmount : 0; const cgst=gstAmount / 2; const sgst=gstAmount / 2;
        const grandTotal=invoice.finalAmount; %>

        <table class="summary">

            <tr>
                <td>Amount:</td>
                <td class="text-right">
                    ₹<%= subTotal.toFixed(2) %>
                </td>
            </tr>

            <tr>
                <td>Addon:</td>
                <td class="text-right">
                    ₹0.00
                </td>
            </tr>

            <tr>
                <td>Express Amount:</td>
                <td class="text-right">
                    ₹<%= invoice.expressCharge || 0 %>
                </td>
            </tr>

            <tr>
                <td>Discount:</td>
                <td class="text-right">
                    ₹<%= invoice.discount || 0 %>
                </td>
            </tr>

            <% if(invoice.applyGST){ %>

                <tr>
                    <td>SGST:</td>
                    <td class="text-right">
                        ₹<%= (invoice.gstAmount/2).toFixed(2) %>
                    </td>
                </tr>

                <tr>
                    <td>CGST:</td>
                    <td class="text-right">
                        ₹<%= (invoice.gstAmount/2).toFixed(2) %>
                    </td>
                </tr>

                <% } %>

                    <tr class="grand-total">
                        <td>TOTAL</td>
                        <td class="text-right">
                            ₹<%= invoice.finalAmount.toFixed(2) %>
                        </td>
                    </tr>

        </table>

        <div class="disclaimer">

            Disclaimer:
            I hereby acknowledge that I accept the service

            <span style="
                color:#8cc63f;
                font-weight:bold;
                ">
                terms & conditions*
            </span>

        </div>

        <div class="page-number">
            Page: 1 of 2
        </div>

        <div class="contact-footer">

            Contact Support:

            &nbsp;&nbsp;&nbsp;

            9999759911

            &nbsp;&nbsp;&nbsp;

            support@uclean.in

        </div>


        <!-- Page 2  -->

        <div style="page-break-before: always;"></div>
        <div style="
                background:#00573f;
                padding:20px;
                margin:-20px -20px 30px -20px;
                display:flex;
                justify-content:space-between;
                align-items:center;
                ">

            <!-- <img src="/images/uc-white.png" alt="logo" style="height:60px;"> -->
            <div>
                <div class="logo">
                    UClean
                </div>

                <div>
                    We ❤️ Laundry
                </div>
            </div>


            <div style="
                    color:white;
                    font-size:20px;
                    font-weight:bold;
                    ">
                www.ucleanlaundry.com
            </div>

        </div>
