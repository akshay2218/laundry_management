<div class="container-fluid">

  <div class="card">

    <div class="card-body">

      <div class="d-flex justify-content-between mb-4">

        <div>

          <h3>

            Invoice

            <%= invoice.invoiceNumber %>

          </h3>

          <p>

            Generated:

            <%= new Date(invoice.generatedAt) .toLocaleString() %>

          </p>

        </div>

      </div>

      <table id="dataTable" class="table table-hover">

        <thead>

          <tr>

            <th>Item</th>
            <th>Qty</th>
            <th>Rate</th>
            <th>Amount</th>

          </tr>

        </thead>

        <tbody>

          <% invoice.items.forEach(item=> { %>

            <tr>

              <td>
                <%= item.itemName %>
              </td>

              <td>
                <%= item.quantity %>
              </td>

              <td>
                ₹<%= item.rate %>
              </td>

              <td>
                ₹<%= item.amount %>
              </td>

            </tr>

            <% }) %>

        </tbody>

      </table>

      <div class="invoice-total">

        <div>

          Subtotal:
          ₹<%= invoice.subtotal %>

        </div>

        <div>

          GST:
          ₹<%= invoice.gstAmount %>

        </div>

        <div>

          Final Amount:

          <strong>

            ₹<%= invoice.finalAmount %>

          </strong>

        </div>

      </div>

    </div>

  </div>

</div>