<div class="container-fluid">

    <div class="card">
  
      <div class="card-body">
  
        <h3 class="mb-4">
          Add Price Item
        </h3>
  
        <form
          method="POST"
          action="/pricing/items/create">
  
          <div class="row">
  
            <div class="col-md-6 mb-3">
  
              <label class="form-label">
                Service
              </label>
  
              <select
                name="serviceId"
                class="form-select">
  
                <% services.forEach(service => { %>
  
                <option
                  value="<%= service._id %>">
  
                  <%= service.name %>
  
                </option>
  
                <% }) %>
  
              </select>
  
            </div>
  
            <div class="col-md-6 mb-3">
  
              <label class="form-label">
                Category
              </label>
  
              <input
                type="text"
                name="category"
                class="form-control"
                required>
  
            </div>
  
          </div>
  
          <div class="row">
  
            <div class="col-md-6 mb-3">
  
              <label class="form-label">
                Item Name
              </label>
  
              <input
                type="text"
                name="itemName"
                class="form-control"
                required>
  
            </div>
  
            <div class="col-md-6 mb-3">
  
              <label class="form-label">
                Price
              </label>
  
              <input
                type="number"
                step="0.01"
                name="price"
                class="form-control"
                required>
  
            </div>
  
          </div>
  
          <button
            class="btn btn-primary">
  
            Save Item
  
          </button>
  
        </form>
  
      </div>
  
    </div>
  
  </div>