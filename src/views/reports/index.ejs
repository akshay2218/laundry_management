<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
  
      <div>
  
        <h3 class="page-title">
          Reports Dashboard
        </h3>
  
        <p class="text-muted mb-0">
          Revenue and GST reporting
        </p>
  
      </div>
  
      <form
        method="GET"
        action="/reports">
  
        <div class="d-flex gap-2">
  
          <input
            
class="form-control datepicker"
            name="fromDate"
            class="form-control">
  
          <input
            
class="form-control datepicker"
            name="toDate"
            class="form-control">
  
          <button
            class="btn btn-primary">
  
            Apply
  
          </button>
  
        </div>
  
      </form>
  
    </div>
  
    <div class="row">
  
      <div class="col-lg-3 mb-3">
  
        <div class="report-card">
  
          <div class="report-title">
            Total Orders
          </div>
  
          <h3>
            <%= stats.totalOrders || 0 %>
          </h3>
  
        </div>
  
      </div>
  
      <div class="col-lg-3 mb-3">
  
        <div class="report-card">
  
          <div class="report-title">
            Revenue
          </div>
  
          <h3>
  
            ₹<%= stats.revenue || 0 %>
  
          </h3>
  
        </div>
  
      </div>
  
      <div class="col-lg-3 mb-3">
  
        <div class="report-card">
  
          <div class="report-title">
            GST
          </div>
  
          <h3>
  
            ₹<%= stats.gst || 0 %>
  
          </h3>
  
        </div>
  
      </div>
  
      <div class="col-lg-3 mb-3">
  
        <div class="report-card">
  
          <div class="report-title">
            Delivered
          </div>
  
          <h3>
  
            <%= stats.delivered || 0 %>
  
          </h3>
  
        </div>
  
      </div>
  
    </div>
  
    <div class="card">
  
      <div class="card-body">
  
        <h5 class="mb-3">
          Reports
        </h5>
  
        <div class="list-group">
  
          <a
            href="/reports/gst"
            class="list-group-item list-group-item-action">
  
            GST Report
  
          </a>
  
        </div>
  
      </div>
  
    </div>
  
  </div>