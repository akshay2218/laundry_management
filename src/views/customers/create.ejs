<div class="container-fluid">

    <div class="card customer-form-card">
  
      <div class="card-body">
  
        <h3 class="mb-4">
          Add Customer
        </h3>
  
        <% if(errors.length){ %>
  
        <div class="alert alert-danger">
  
          <ul class="mb-0">
  
            <% errors.forEach(error => { %>
  
            <li>
              <%= error.msg %>
            </li>
  
            <% }) %>
  
          </ul>
  
        </div>
  
        <% } %>
  
        <form
          action="/customers/create"
          method="POST">
  
          <div class="row">
  
            <div class="col-md-6 mb-3">
  
              <label class="form-label">
                Name
              </label>
  
              <input
                type="text"
                name="name"
                class="form-control"
                required>
  
            </div>
  
            <div class="col-md-6 mb-3">
  
              <label class="form-label">
                Phone
              </label>
  
              <input
                type="text"
                name="phone"
                class="form-control"
                required>
  
            </div>
  
            <div class="col-md-6 mb-3">
  
              <label class="form-label">
                Email
              </label>
  
              <input
                type="email"
                name="email"
                class="form-control">
  
            </div>
  
            <div class="col-md-6 mb-3">
  
              <label class="form-label">
                Short Address
              </label>
  
              <input
                type="text"
                name="shortAddress"
                class="form-control">
  
            </div>
          </div>
  
          <button
            class="btn btn-primary">
  
            Save Customer
  
          </button>
  
        </form>
  
      </div>
  
    </div>
  
  </div>