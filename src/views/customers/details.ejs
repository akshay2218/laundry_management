<div class="container-fluid">

  <div class="row">

    <!-- Customer Details -->
    <div class="col-lg-4">
      <!-- Customer Info -->
      <div class="card mb-4">

        <div class="card-body">

          <h4>
            <%= customer.name %>
          </h4>

          <p>
            <%= customer.phone %>
          </p>

          <p>
            <%= customer.shortAddress || '-' %>
          </p>

          <a href="/customers/<%= customer._id %>/edit" class="btn btn-outline-primary">

            Edit Customer

          </a>

        </div>

      </div>

      <!-- Addressess card -->
      <div class="card">

        <div class="card-body">

          <h5 class="mb-3">

            Addresses

          </h5>

          <% addresses.forEach(address=> { %>

            <div class="address-card">

              <strong>

                <%= address.addressType %>

              </strong>

              <div>

                <%= address.houseNo %>

              </div>

              <div>

                <%= address.apartment %>

              </div>

              <div>

                <%= address.landmark %>

              </div>

            </div>

            <% }) %>

              <button type="button" class="btn btn-outline-success w-100" data-bs-toggle="modal"
                data-bs-target="#addressModal">

                + Add New Address

              </button>
        </div>

      </div>

    </div>

    <!-- Orders -->
    <div class="col-lg-8">

      <!-- Order Summary -->
      <div class="card mb-8">

        <div class="card-body">

          <div class="d-flex justify-content-between align-items-center mb-4">

            <h5>

              Order Summary

            </h5>

            <a href="/orders/create/<%= customer._id %>" class="btn btn-primary">

              Create Order

            </a>

          </div>

          <div class="row">

            <div class="col-md-4">

              <div class="summary-box">

                <h4>

                  <%= customer.totalOrders %>

                </h4>

                <p>Total Orders</p>

              </div>

            </div>

            <div class="col-md-4">

              <div class="summary-box">

                <h4>

                  ₹<%= customer.lifetimeValue %>

                </h4>

                <p>Lifetime Value</p>

              </div>

            </div>

          </div>

        </div>

      </div>

      <!-- Orders table -->
      <div class="card">
        <div class="card-body">

          <% if(orders && orders.length> 0){ %>

            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead>
                  <tr>
                    <th>Order #</th>
                    <th>Pickup Date</th>
                    <th>Status</th>
                    <th>Invoice</th>
                    <th width="120">Actions</th>
                  </tr>
                </thead>

                <tbody>
                  <% orders.forEach(order=> { %>
                    <tr>
                      <td><strong><%= order.orderNumber %></strong></td>
                      <td><%= new Date(order.pickupDate) .toLocaleDateString() %> </td>
                      <td>
                        <span class="badge status-badge status-<%= order.status.toLowerCase() %>">
                          <%= order.status %>
                        </span>
                      </td>
                      <td>
                        <% if (order.invoiceId) { %>
                          <!-- <pre><%= JSON.stringify(order.invoiceId, null, 2) %></pre> -->
                          <a href="/invoices/<%= order.invoiceId._id %>/download" class="btn btn-success">
                            <i class="bi bi-download"></i>
                            Download PDF
                          </a>
                          <% } else { %>
                            <span class="text-muted">Not Available</span>
                            <% } %>
                      </td>

                      <td>

                        <a href="/orders/<%= order._id %>" class="btn btn-sm btn-outline-primary">

                          View

                        </a>

                      </td>

                    </tr>

                    <% }) %>

                </tbody>

              </table>

            </div>

            <% } else { %>

              <div class="empty-state">

                <i class="bi bi-bag display-3 text-muted"></i>

                <h5 class="mt-3">
                  No Orders Found
                </h5>

                <p class="text-muted">

                  Create your first order to get started.

                </p>

              </div>

              <% } %>

        </div>
      </div>
    </div>

  </div>

</div>

<%- include('../partials/address-modal') %>