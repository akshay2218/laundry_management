<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
  
      <div>
  
        <h3>
          <%= order.orderNumber %>
        </h3>
  
        <p class="text-muted mb-0">
  
          Created on
  
          <%= new Date(order.createdAt)
            .toLocaleDateString() %>
  
        </p>
  
      </div>
  
      <a
        href="/orders/<%= order._id %>/invoice"
        class="btn btn-success">
  
        Generate Invoice
  
      </a>
  
    </div>
  
    <div class="row">
  
      <div class="col-lg-4">
  
        <div class="card mb-4">
  
          <div class="card-body">
  
            <h5>
              Customer
            </h5>
  
            <p class="mb-1">
  
              <%= order.customerId?.name %>
  
            </p>
  
            <p>
  
              <%= order.customerId?.phone %>
  
            </p>
  
          </div>
  
        </div>
  
        <div class="card">
  
          <div class="card-body">
  
            <h5>
              Order Info
            </h5>
  
            <div class="summary-item">
  
              <span>Status</span>
  
              <strong>
  
                <%= order.status %>
  
              </strong>
  
            </div>
  
            <div class="summary-item">
  
              <span>Pickup Date</span>
  
              <strong>
  
                <%= new Date(order.pickupDate)
                  .toLocaleDateString() %>
  
              </strong>
  
            </div>
  
            <div class="summary-item">
  
              <span>Pickup Time</span>
  
              <strong>
  
                <%= order.pickupTime %>
  
              </strong>
  
            </div>
  
          </div>
  
        </div>
  
      </div>
  
      <div class="col-lg-8">
  
        <div class="card mb-4">
  
          <div class="card-body">
  
            <h5 class="mb-3">
  
              Update Status
  
            </h5>
  
            <form
              method="POST"
              action="/orders/<%= order._id %>/status">
  
              <div class="row">
  
                <div class="col-md-8">
  
                  <select
                    class="form-select"
                    name="status">
  
                    <option value="NEW">
                      NEW
                    </option>
  
                    <option value="IN_PROCESS">
                      IN PROCESS
                    </option>
  
                    <option value="READY">
                      READY
                    </option>
  
                    <option value="ASSIGNED">
                      ASSIGNED
                    </option>
  
                    <option value="DELIVERED">
                      DELIVERED
                    </option>
  
                  </select>
  
                </div>
  
                <div class="col-md-4">
  
                  <button
                    class="btn btn-primary w-100">
  
                    Update
  
                  </button>
  
                </div>
  
              </div>
  
            </form>
  
          </div>
  
        </div>
  
        <div class="card mb-4">
  
          <div class="card-body">
  
            <h5 class="mb-3">
  
              Assign Delivery
  
            </h5>
  
            <form
              method="POST"
              action="/orders/<%= order._id %>/assign-delivery">
  
              <div class="row">
  
                <div class="col-md-8">
  
                  <select
                    name="deliveryPersonId"
                    class="form-select">
  
                    <% if(typeof deliveryPersons !== 'undefined'){ %>
  
                      <% deliveryPersons.forEach(person => { %>
  
                      <option
                        value="<%= person._id %>">
  
                        <%= person.name %>
  
                      </option>
  
                      <% }) %>
  
                    <% } %>
  
                  </select>
  
                </div>
  
                <div class="col-md-4">
  
                  <button
                    class="btn btn-success w-100">
  
                    Assign
  
                  </button>
  
                </div>
  
              </div>
  
            </form>
  
          </div>
  
        </div>
  
        <div class="card">
  
          <div class="card-body">
  
            <h5 class="mb-3">
  
              Status History
  
            </h5>
  
            <table
  id="dataTable"
  class="table table-hover">
  
              <thead>
  
              <tr>
  
                <th>Status</th>
                <th>Date</th>
  
              </tr>
  
              </thead>
  
              <tbody>
  
              <% order.statusHistory.forEach(history => { %>
  
              <tr>
  
                <td>
  
                  <%= history.status %>
  
                </td>
  
                <td>
  
                  <%= new Date(history.changedAt)
                    .toLocaleString() %>
  
                </td>
  
              </tr>
  
              <% }) %>
  
              </tbody>
  
            </table>
  
          </div>
  
        </div>
  
      </div>
  
    </div>
  
  </div>