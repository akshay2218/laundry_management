<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">
  
      <div>
  
        <h3 class="page-title mb-1">
          Orders Dashboard
        </h3>
  
        <!-- <p class="text-muted mb-0">
          Manage and track all laundry orders
        </p> -->
  
      </div>
  
      <a
        href="/customers"
        class="btn btn-primary">
  
        <i class="bi bi-plus-lg"></i>
        Add Order
  
      </a>
  
    </div>
  
    <div class="card mb-4">
  
      <div class="card-body">
  
        <form
          method="GET"
          action="/dashboard">
  
          <div class="row">
  
            <div class="col-md-4">
  
              <input
                type="text"
                name="search"
                class="form-control"
                placeholder="Search Order / Customer / Phone">
  
            </div>
  
            <div class="col-md-3">
  
              <input
                
class="form-control datepicker"
                name="pickupDate"
                class="form-control">
  
            </div>
  
            <div class="col-md-3">
  
              <select
                class="form-select"
                name="status">
  
                <option value="">
                  All Status
                </option>
  
                <option value="NEW">
                  New
                </option>
  
                <option value="IN_PROCESS">
                  In Process
                </option>
  
                <option value="READY">
                  Ready
                </option>
  
                <option value="ASSIGNED">
                  Assigned
                </option>
  
                <option value="DELIVERED">
                  Delivered
                </option>


                <option value="PAYMENT_PENDING">
                  PAYMENT PENDING
                </option>

                <option value="PAYMENT_COMPLETED">
                  PAYMENT DONE
                </option>
  
              </select>
  
            </div>
  
            <div class="col-md-2">
  
              <button
                type="submit"
                class="btn btn-primary w-100">
  
                Search
  
              </button>
  
            </div>
  
          </div>
  
        </form>
  
      </div>
  
    </div>
  
    <ul
      class="nav nav-tabs dashboard-tabs mb-4">
  
      <li class="nav-item">
  
        <a
          class="nav-link <%= !query?.status ? 'active' : '' %>"
          href="/dashboard">
  
          All
  
        </a>
  
      </li>
  
      <li class="nav-item">
  
        <a
          class="nav-link <%= query?.status === 'NEW' ? 'active' : '' %>"
          href="/dashboard?status=NEW">
  
          New Orders
  
        </a>
  
      </li>
  
      <li class="nav-item">
  
        <a
          class="nav-link <%= query?.status === 'IN_PROCESS' ? 'active' : '' %>"
          href="/dashboard?status=IN_PROCESS">
  
          In Process
  
        </a>
  
      </li>
  
      <li class="nav-item">
  
        <a
          class="nav-link <%= query?.status === 'READY' ? 'active' : '' %>"
          href="/dashboard?status=READY">
  
          Ready
  
        </a>
  
      </li>
  
      <li class="nav-item">
  
        <a
          class="nav-link <%= query?.status === 'ASSIGNED' ? 'active' : '' %>"
          href="/dashboard?status=ASSIGNED">
  
          Assigned
  
        </a>
  
      </li>
  
      <li class="nav-item">
  
        <a
          class="nav-link <%= query?.status === 'DELIVERED' ? 'active' : '' %>"
          href="/dashboard?status=DELIVERED">
  
          Delivered
  
        </a>
  
      </li>

      <li class="nav-item">
  
        <a
          class="nav-link <%= query?.status === 'PAYMENT_PENDING' ? 'active' : '' %>"
          href="/dashboard?status=PAYMENT_PENDING">
  
          PAYMENT PENDING
  
        </a>
  
      </li>


      <li class="nav-item">
  
        <a
          class="nav-link <%= query?.status === 'PAYMENT_COMPLETED' ? 'active' : '' %>"
          href="/dashboard?status=PAYMENT_COMPLETED">
  
          PAYMENT COMPLETED
  
        </a>
  
      </li>
  
    </ul>
  
    <div class="card">
  
      <div class="card-body p-0">
  
        <% if(orders && orders.length > 0){ %>
  
        <div class="table-responsive">
  
          <table
            class="table table-hover align-middle mb-0">
  
            <thead>
  
            <tr>
  
              <th>Order #</th>

              <th>Address</th>
  
              <th>Customer</th>
  
              <th>Phone</th>
  
              <th>Pickup Date</th>
  
              <th>Status</th>
              <th>Invoice Amount</th>
              <th>Invoice</th>
  
              <th width="120">
                Actions
              </th>
  
            </tr>
  
            </thead>
  
            <tbody>
  
            <% orders.forEach(order => { %>
  
            <tr>
  
              <td>
                <strong>
                  <%= order.orderNumber %>
                </strong>
              </td>
  
              <td>
                <%= order.customerId.shortAddress %>
              </td>

              <td>
                <%= order.customerId?.name %>
              </td>
  
              <td>
                <%= order.customerId?.phone %>
              </td>
  
              <td>
                <%= new Date(order.pickupDate)
                  .toLocaleDateString() %>
              </td>
  
              <td>
  
                <span
                  class="badge status-badge status-<%= order.status.toLowerCase() %>">
  
                  <%= order.status %>
  
                </span>
  
              </td>
  
              <td>
                <% if (order.invoiceId) { %>
                  ₹<%= order.invoiceId?.finalAmount %>                  
                <% } else { %>
                  <span class="text-muted">Not Available</span>
                <% } %>
              </td>

              <td>
                <% if (order.invoiceId) { %>
                  <!-- <pre><%= JSON.stringify(order.invoiceId, null, 2) %></pre> -->
                  <a
                    href="/invoices/<%= order.invoiceId._id %>/download"
                    class="btn btn-success"
                  >
                    <i class="bi bi-download"></i>
                    Download PDF
                  </a>
                <% } else { %>
                  <span class="text-muted">Not Available</span>
                <% } %>
              </td>
  
              <td>
  
                <a
                  href="/orders/<%= order._id %>"
                  class="btn btn-sm btn-outline-primary">
  
                  View
  
                </a>
  
              </td>
  
            </tr>
  
            <% }) %>
  
            </tbody>
  
          </table>
  
        </div>
  
        <% } else { %>
  
        <div
          class="empty-state">
  
          <i
            class="bi bi-bag display-3 text-muted"></i>
  
          <h5 class="mt-3">
            No Orders Found
          </h5>
  
          <p class="text-muted">
  
            Create your first order to get started.
  
          </p>
  
        </div>
  
        <% } %>
  
      </div>
  
    </div>
  
  </div>